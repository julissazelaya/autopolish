{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-core/autopolish//nextflow_schema.json",
    "title": "nf-core/autopolish pipeline parameters",
    "description": "Automated end-to-end assembly of bacterial genomes from Oxford Nanopore Technology (ONT) long-read sequencing data.",
    "type": "object",
    "$defs": {
        "input_output_options": {
            "title": "Input/output Options",
            "type": "object",
            "fa_icon": "fas fa-terminal",
            "description": "Define where the pipeline should find input data and save output data.",
            "required": ["input", "input_type", "outdir"],
            "properties": {
                "input": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "schema": "assets/schema_input.json",
                    "mimetype": "text/csv",
                    "pattern": "^\\S+\\.csv$",
                    "description": "The input directory where the input files are located.",
                    "help_text": "You will need to create a design file with information about the samples in your experiment before running the pipeline. Use this parameter to specify its location. It has to be a comma-separated file with 3 columns, and a header row.",
                    "fa_icon": "fas fa-file-csv"
                },
                "input_type": {
                    "type": "string",
                    "description": "Input file type: fastq, pod5, or bam"
                },
                "outdir": {
                    "type": "string",
                    "format": "directory-path",
                    "description": "The output directory where the results will be saved. You have to use absolute paths to storage on Cloud infrastructure.",
                    "fa_icon": "fas fa-folder-open"
                }
            }
        },
        "basecalling_demultiplexing": {
            "title": "Basecalling & Demultiplexing",
            "type": "object",
            "description": "",
            "default": "",
            "properties": {
                "dorado_models_dir": {
                    "type": "string",
                    "default": "/mrsnStorage/resources/dorado_models",
                    "description": "Path to local Dorado models directory"
                },
                "dorado_model": {
                    "type": "string",
                    "default": "dna_r10.4.1_e8.2_400bps_sup@v5.2.0",
                    "description": "Dorado basecalling model"
                },
                "barcode_kit": {
                    "type": "string",
                    "description": "Barcode kit for demultiplexing -- required for basecalling"
                },
                "dorado_modifications": {
                    "type": "string",
                    "description": "Dorado modification calling model"
                }
            }
        },
        "genome_assembly": {
            "title": "Genome Assembly",
            "type": "object",
            "description": "",
            "default": "",
            "properties": {
                "min_read_depth": {
                    "type": "integer",
                    "default": 50,
                    "description": "Minimum read depth for assembly"
                },
                "read_type": {
                    "type": "string",
                    "default": "ont_r10",
                    "description": "Read type passed to assemblers"
                },
                "flye_mode": {
                    "type": "string",
                    "default": "--nano-hq",
                    "description": "Flye assembly mode flag"
                },
                "metamdbg_input_type": {
                    "type": "string",
                    "default": "ont",
                    "description": "metaMDBG input type"
                },
                "plassembler_db": {
                    "type": "string",
                    "default": "/mrsnStorage/resources/plassembler",
                    "description": "Path to Plassembler database"
                },
                "canu_mode": {
                    "type": "string",
                    "default": "-nanopore",
                    "description": "Canu assembly mode flag"
                }
            }
        },
        "genome_alignment": {
            "title": "Genome Alignment",
            "type": "object",
            "description": "",
            "default": "",
            "properties": {
                "rg_tag": {
                    "type": "string",
                    "default": "ID:A\\\\tDS:basecall_model=dna_r10.4.1_e8.2_400bps_sup@v5.2.0",
                    "description": "Read group tag for BAM header"
                }
            }
        },
        "resources": {
            "title": "Resources",
            "type": "object",
            "description": "",
            "default": "",
            "properties": {
                "threads": {
                    "type": "integer",
                    "default": 96
                }
            }
        },
        "boilerplate": {
            "title": "Boilerplate",
            "type": "object",
            "description": "",
            "default": "",
            "properties": {
                "publish_dir_mode": {
                    "type": "string",
                    "default": "copy",
                    "description": "Method for publishing results to output directory"
                },
                "email": {
                    "type": "string",
                    "description": "Email address for completion notification"
                },
                "email_on_fail": {
                    "type": "string",
                    "description": "Email address for failure notification"
                },
                "plaintext_email": {
                    "type": "boolean",
                    "description": "Send plain-text email instead of HTML"
                },
                "monochrome_logs": {
                    "type": "boolean",
                    "description": "Disable ANSI colour in log output"
                },
                "hook_url": {
                    "type": "string",
                    "description": "Slack or Teams hook URL for notifications"
                },
                "pipelines_testdata_base_path": {
                    "type": "string",
                    "default": "https://raw.githubusercontent.com/nf-core/test-datasets/"
                },
                "config_profile_name": {
                    "type": "string"
                },
                "config_profile_description": {
                    "type": "string"
                },
                "custom_config_version": {
                    "type": "string",
                    "default": "master"
                },
                "custom_config_base": {
                    "type": "string",
                    "default": "https://raw.githubusercontent.com/nf-core/configs/master"
                },
                "config_profile_contact": {
                    "type": "string"
                },
                "config_profile_url": {
                    "type": "string"
                }
            }
        },
        "generic_options": {
            "title": "Generic options",
            "type": "object",
            "fa_icon": "fas fa-file-import",
            "description": "Less common options for the pipeline, typically set in a config file.",
            "help_text": "These options are common to all nf-core pipelines and allow you to customise some of the core preferences for how the pipeline runs.\n\nTypically these options would be set in a Nextflow config file loaded for all pipeline runs, such as `~/.nextflow/config`.",
            "properties": {
                "version": {
                    "type": "boolean",
                    "description": "Display version and exit.",
                    "fa_icon": "fas fa-question-circle",
                    "hidden": true
                },
                "trace_report_suffix": {
                    "type": "string",
                    "fa_icon": "far calendar",
                    "description": "Suffix to add to the trace report filename. Default is the date and time in the format yyyy-MM-dd_HH-mm-ss.",
                    "hidden": true
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/input_output_options"
        },
        {
            "$ref": "#/$defs/basecalling_demultiplexing"
        },
        {
            "$ref": "#/$defs/genome_assembly"
        },
        {
            "$ref": "#/$defs/genome_alignment"
        },
        {
            "$ref": "#/$defs/resources"
        },
        {
            "$ref": "#/$defs/boilerplate"
        },
        {
            "$ref": "#/$defs/generic_options"
        }
    ]
}
